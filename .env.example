DATABASE_URL=""

# --- URL pubblici usati da auth, link email e redirect Stripe ---
ESIGENTA_WEB_URL="http://localhost:3000"
ESIGENTA_APP_URL="http://localhost:3000"
ESIGENTA_ADMIN_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Vercel li valorizza nel deployment; in locale possono restare vuoti.
VERCEL_PROJECT_PRODUCTION_URL=""
VERCEL_URL=""

# RESEND_FROM_EMAIL must use a Resend-verified sending domain in production
# (resend-client.ts throws if this is unset when NODE_ENV=production).
# Display name must be "Esigenta" everywhere — do not use any other brand.
# See docs/pre-release/EMAIL_PRODUCTION_HARDENING.md for the domain
# verification steps. Replace your-verified-domain.it once the real domain
# is confirmed and verified in the Resend dashboard.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Esigenta <noreply@esigenta.it>"

# --- UploadThing (customer request photos only) ---
UPLOADTHING_TOKEN=""

# --- Cloudflare R2 (private company documents — server-side only, never NEXT_PUBLIC_) ---
# R2_ENDPOINT is the S3-compatible endpoint from the Cloudflare dashboard
# (https://<account-id>.r2.cloudflarestorage.com) — the account id is
# already embedded in it, so no separate R2_ACCOUNT_ID is needed.
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_ENDPOINT=""
R2_BUCKET_NAME=""
R2_REGION="auto"

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
ESIGENTA_DEBUG_AUTH_ORIGINS="false"

# --- Super admin bootstrap ---
# Used by: pnpm --filter @esigenta/auth admin:bootstrap
# Creates the first admin auth user when missing, then ensures AdminProfile.role=SUPER_ADMIN.
# Required: email and password. Name is optional and only used when creating the user.
ESIGENTA_SUPER_ADMIN_EMAIL=""
ESIGENTA_SUPER_ADMIN_PASSWORD=""
ESIGENTA_SUPER_ADMIN_NAME=""

# --- Stripe ---
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
ESIGENTA_DEBUG_STRIPE="false"
