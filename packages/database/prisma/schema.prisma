generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

///////////////////////////////////////////////////////////
// CORE ORGANIZATION LAYER
///////////////////////////////////////////////////////////

model Sector {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories Category[]
}

model Category {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?

  /**
   * PROFESSIONAL IDENTITY
   * Category defines:
   * - professional identity
   * - onboarding grouping
   * - navigation grouping
   * - trust grouping
   * - base professional coverage for marketplace eligibility
   * Category is NOT:
   * - customer intent
   * - SEO runtime
   * - a precise operational specialization
   */

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sectorId String
  sector   Sector @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  aliases   CategoryAlias[]
  companies CompanyCategory[]

  /**
   * FROZEN TAXONOMY (Phase 14 — renamed from defaultProjectGroupIds)
   * ProjectGroup ids associated with this Category. Used for: onboarding
   * bootstrap, search expansion, discovery, SEO/profession pages, and
   * marketplace dashboard visibility. NEVER used for: matching, dispatch,
   * notifications, or authorization — Category still never participates
   * in matching. See docs/taxonomy.md and
   * docs/archive-legacy/refoundation/taxonomy-refoundation/14_DISCOVERY_AND_VISIBILITY_CUTOVER_REPORT.md.
   */
  projectGroupIds String[] @default([])

  @@index([sectorId])
}

/**
 * FROZEN TAXONOMY (Phase 8 — additive; Phase 14 added aliases)
 * Persisted, first-class, NON-operational: catalog organization, public
 * navigation, SEO hubs, discovery, analytics, reporting. Must never
 * participate in matching, dispatch, notifications, requests, or funnel
 * routing. See docs/taxonomy.md.
 */
model ProjectGroup {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  interventions Intervention[]
  aliases       ProjectGroupAlias[]

  @@index([name])
}

model ProjectGroupAlias {
  id String @id @default(cuid())

  value String @unique

  projectGroupId String
  projectGroup   ProjectGroup @relation(fields: [projectGroupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([projectGroupId])
}

///////////////////////////////////////////////////////////
// CUSTOMER INTENT LAYER
///////////////////////////////////////////////////////////

model Intervention {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?

  /**
   * CUSTOMER INTENT
   * Represents:
   * - customer goals
   * - customer language
   * - customer problems
   * - funnel entry
   * Intervention is NOT:
   * - operational capability
   */

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aliases InterventionAlias[]

  /**
   * FROZEN TAXONOMY (Phase 8 — additive, not yet read by any code path)
   * Nullable until the Phase 9+ backfill assigns every Intervention to its
   * ProjectGroup. ProjectGroup is NON-operational — this relation exists
   * for catalog organization only, never for matching. onDelete: SetNull
   * so ProjectGroup catalog reorganization never blocks on Intervention
   * rows. See docs/taxonomy.md.
   */
  projectGroupId String?
  projectGroup   ProjectGroup? @relation(fields: [projectGroupId], references: [id], onDelete: SetNull)

  /**
   * LEGACY DB COLUMN. Kept pending a dedicated migration because production
   * data shape changes must be explicit. The current funnel does not read this
   * field; taxonomy sync does not write it.
   */
  runtimePresetSlugs String[] @default([])

  companyInterventions CompanyIntervention[]
  requests             Request[]

  @@index([name])
  @@index([projectGroupId])
}

///////////////////////////////////////////////////////////
// ALIASES
///////////////////////////////////////////////////////////

model InterventionAlias {
  id String @id @default(cuid())

  value String @unique

  interventionId String
  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([interventionId])
}

model CategoryAlias {
  id String @id @default(cuid())

  value String @unique

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([categoryId])
}

///////////////////////////////////////////////////////////
// GEO DOMAIN (docs/archive-legacy/refoundation/geo-refoundation/01_DESIGN.md)
///////////////////////////////////////////////////////////

/**
 * GOOGLE_PLACES: resolved live from a Google Places Autocomplete selection
 * via resolvePlaceFromGooglePlace (@esigenta/shared) — the only path that
 * produces new GeoLocation rows going forward.
 * LEGACY_BACKFILL: produced once, by the geo-refoundation migration, for
 * pre-existing Company/Request rows that never had a placeId captured.
 * Never written by application code after the migration.
 */
enum GeoSource {
  GOOGLE_PLACES
  LEGACY_BACKFILL
}

/**
 * One row = one resolved place, captured once, never edited field-by-field.
 * Company and Request each hold at most one GeoLocation through a unique
 * FK (geoLocationId) — this is the only table in the schema with
 * address/city/postalCode/province/latitude/longitude columns. There is no
 * parallel copy of any of these fields anywhere else.
 *
 * placeId is nullable at the schema level only to allow LEGACY_BACKFILL
 * rows whose original Google Place was never captured (see
 * docs/archive-legacy/refoundation/geo-refoundation/02_BACKFILL_AUDIT.md) — every row written through
 * the write boundary (packages/domain/src/company/geo,
 * packages/domain/src/request/geo) always has one.
 */
model GeoLocation {
  id String @id @default(cuid())

  placeId          String?
  formattedAddress String
  city             String
  postalCode       String?
  province         String?
  latitude         Float
  longitude        Float
  source           GeoSource @default(GOOGLE_PLACES)
  resolvedAt       DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company?
  request Request?

  @@index([city])
  @@index([latitude, longitude])
  @@index([placeId])
}

///////////////////////////////////////////////////////////
// RUNTIME OPERATIONAL LAYER
///////////////////////////////////////////////////////////

enum CompanyStatus {
  PENDING_REVIEW
  APPROVED
  SUSPENDED
  BLOCKED
}

model Company {
  id String @id @default(cuid())

  name              String
  vatNumber         String  @unique
  phone             String
  website           String?
  operatingRadiusKm Int     @default(30)

  /**
   * GEO REFOUNDATION (docs/archive-legacy/refoundation/geo-refoundation/01_DESIGN.md)
   * The company's operating address/coordinates are not scalar columns
   * here anymore — they live in exactly one place, GeoLocation, reached
   * through this relation. There is no parallel address/city/lat/lng on
   * this model. See packages/database/src/geo/set-company-location.ts for
   * the only code allowed to attach/replace it.
   */
  geoLocationId String?      @unique
  geoLocation   GeoLocation? @relation(fields: [geoLocationId], references: [id])

  isActive Boolean @default(true)

  deletedAt DateTime?

  status      CompanyStatus @default(PENDING_REVIEW)
  approvedAt  DateTime?
  suspendedAt DateTime?
  blockedAt   DateTime?

  /**
   * AUDIT — who/why for the most recent approve/suspend/block action.
   * Deliberately a single generic pair, not one per action: approvedAt/
   * suspendedAt/blockedAt above already record *when* each transition last
   * happened; this only needs to answer "who did the current status, and
   * why" for the admin UI, not a full history. Same FK pattern as
   * Request's archivedByAdminUserId/archiveReason.
   */
  statusChangedByAdminUserId String?
  statusChangedByAdminUser   User?     @relation("CompanyStatusChangeActor", fields: [statusChangedByAdminUserId], references: [id], onDelete: SetNull)
  statusChangeReason         String?

  /**
   * ONBOARDING CONTEXT ONLY
   * Captures the first professional category selected in the public signup flow.
   * Runtime matching must use CompanyCategory, not this onboarding snapshot.
   */
  onboardingCategorySlug String?

  /**
   * IMPORTANT
   * Company marketplace eligibility is defined by:
   * - CompanyCategory as broad professional coverage
   * - CompanyIntervention as the sole matching/dispatch signal
   * NOT by:
   * - sectors
   * - SEO
   * - domains
   */

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories  CompanyCategory[]
  interventions CompanyIntervention[]
  memberships CompanyMembership[]

  creditAccount            CompanyCreditAccount?
  creditOrders             CreditOrder[]
  creditTransactions       CompanyCreditTransaction[]
  creditLots               CreditLot[]
  requestUnlocks           RequestUnlock[]
  savedRequests            CompanySavedRequest[]
  requestDispatches        RequestDispatch[]
  notifications            CompanyNotification[]
  creditRefundRequests     CreditRefundRequest[]
  contactChangeRequests    CompanyContactChangeRequest[]
  conversationParticipants ConversationParticipant[]

  @@index([onboardingCategorySlug])
  @@index([status])
  @@index([createdAt])
  @@index([statusChangedByAdminUserId])
}

model CompanyCategory {
  companyId  String
  categoryId String
  createdAt  DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([companyId, categoryId])
  @@index([categoryId])
}

/**
 * FROZEN TAXONOMY (Phase 8). Intervention is the only matching unit, so
 * this is the sole signal matching/dispatch needs — see
 * docs/archive-legacy/refoundation/taxonomy-refoundation/06_MATCHING_CUTOVER_DESIGN.md.
 */
model CompanyIntervention {
  companyId      String
  interventionId String
  createdAt      DateTime @default(now())

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  intervention Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)

  @@id([companyId, interventionId])
  @@index([companyId])
  @@index([interventionId])
}

///////////////////////////////////////////////////////////
// REQUEST SNAPSHOT LAYER
///////////////////////////////////////////////////////////

enum RequestStatus {
  DRAFT
  PENDING_VERIFICATION
  PENDING_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
  CLOSED
}

enum RequestPhotoStatus {
  TEMPORARY
  ATTACHED
}

enum RequestDispatchStatus {
  CREATED
  CANCELLED
}

enum CompanyNotificationType {
  NEW_REQUEST_AVAILABLE
  CONVERSATION_MESSAGE
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
}

enum NotificationDeliveryStatus {
  PENDING
  SENDING
  SENT
  FAILED
  CANCELLED
}

model User {
  id String @id @default(cuid())

  /**
   * HARD AUTH IDENTITY
   * User represents authenticated actors:
   * - company operators
   * - admin operators
   * User is NOT required for lightweight customer funnel flow.
   */

  email String  @unique
  name  String?

  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  image           String?

  isActive Boolean @default(true)

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyMemberships                   CompanyMembership[]
  adminProfile                         AdminProfile?
  adminCreditTransactions              CompanyCreditTransaction[]    @relation("CreditAdminActor")
  reviewedCreditRefundRequests         CreditRefundRequest[]         @relation("CreditRefundReviewAdmin")
  companyContactChangeRequests         CompanyContactChangeRequest[] @relation("CompanyContactChangeRequestedBy")
  reviewedCompanyContactChangeRequests CompanyContactChangeRequest[] @relation("CompanyContactChangeReviewedBy")
  resolvedConversations                Conversation[]                @relation("ConversationResolvedBy")
  archivedRequests                     Request[]                     @relation("RequestArchivedBy")
  deletedRequests                      Request[]                     @relation("RequestDeletedBy")
  commercialOverriddenRequests         Request[]                     @relation("RequestCommercialOverriddenBy")
  companyStatusChanges                 Company[]                     @relation("CompanyStatusChangeActor")

  sessions                 Session[]
  accounts                 Account[]
  conversationParticipants ConversationParticipant[]
}

model Session {
  id String @id @default(cuid())

  expiresAt DateTime
  token     String   @unique

  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id String @id @default(cuid())

  accountId  String
  providerId String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([providerId, accountId])
}

model Verification {
  id String @id @default(cuid())

  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
}

model Customer {
  id String @id @default(cuid())

  /**
   * SOFT CUSTOMER IDENTITY
   * Customer is created/linked from funnel request verification.
   * It must remain lightweight:
   * - no mandatory password
   * - no forced registration
   * - used for request status/reviews/history
   */

  email String  @unique
  name  String?
  phone String?

  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requests                 Request[]
  conversationParticipants ConversationParticipant[]
}

model CompanyMembership {
  id String @id @default(cuid())

  /**
   * COMPANY ACCESS CONTROL
   * Defines which authenticated User can operate a Company.
   * Company operational profile remains on Company.
   * Services remain on CompanyService.
   * Coverage/radius must remain company-level, not user-level.
   */

  companyId String
  userId    String

  role CompanyMemberRole @default(STAFF)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
  @@index([companyId, role])
  @@index([userId, companyId], map: "idx_company_membership_user_company_s6b")
}

model AdminProfile {
  id String @id @default(cuid())

  /**
   * ADMIN ACCESS CONTROL
   * Admin access is separate from company access.
   * A User becomes an admin only if an AdminProfile exists.
   */

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role AdminRole @default(ADMIN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model CustomerAccessToken {
  id String @id @default(cuid())

  /**
   * CUSTOMER TOKEN ACCESS
   * Used for:
   * - request email verification
   * - request status access
   * - review access
   * Store only tokenHash, never raw token.
   */

  tokenHash String @unique

  purpose CustomerTokenPurpose

  email String

  requestId String?
  request   Request? @relation(fields: [requestId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([email, purpose])
  @@index([requestId])
  @@index([purpose, expiresAt])
  @@index([expiresAt])
}

model Request {
  id          String  @id @default(cuid())
  requestCode String? @unique

  /**
   * MARKETPLACE REQUEST LIFECYCLE
   * Request represents:
   * - verified customer intent
   * - operational request snapshot
   * - marketplace moderation unit
   * Request MUST remain:
   * - taxonomy-independent
   * - runtime-stable
   * - historically stable
   */

  status RequestStatus @default(DRAFT)

  ///////////////////////////////////////////////////////////
  // TAXONOMY SNAPSHOT
  ///////////////////////////////////////////////////////////

  interventionSlug String?

  /**
   * FROZEN TAXONOMY (Phase 8). Resolved once at creation time; never
   * re-resolved. onDelete: Restrict because historical requests must
   * remain stable. interventionSlug remains the permanent, immutable
   * snapshot regardless of this column's lifecycle. See
   * docs/archive-legacy/refoundation/taxonomy-refoundation/06_MATCHING_CUTOVER_DESIGN.md §6.
   */
  interventionId String?
  intervention   Intervention? @relation(fields: [interventionId], references: [id], onDelete: Restrict)

  ///////////////////////////////////////////////////////////
  // CUSTOMER SNAPSHOT
  ///////////////////////////////////////////////////////////

  customerName  String?
  customerEmail String?
  customerPhone String?

  ///////////////////////////////////////////////////////////
  // GEO (docs/archive-legacy/refoundation/geo-refoundation/01_DESIGN.md)
  ///////////////////////////////////////////////////////////

  /**
   * Job-site location. Same model as Company — one GeoLocation row through
   * a unique FK, no scalar address/city/lat/lng columns on Request itself.
   * Written once at creation by
   * packages/database/src/geo/set-request-location.ts; never edited
   * afterward (a request's job site does not move).
   */
  geoLocationId String?      @unique
  geoLocation   GeoLocation? @relation(fields: [geoLocationId], references: [id])

  ///////////////////////////////////////////////////////////
  // FUNNEL SNAPSHOT
  ///////////////////////////////////////////////////////////

  /**
   * IMPORTANT
   * Stores:
   * - runtime answers
   * - funnel structured data
   * - operational context
   * Avoid rigid funnel columns.
   */

  structuredData Json?

  ///////////////////////////////////////////////////////////
  // MODERATION
  ///////////////////////////////////////////////////////////

  moderationNotes String?

  reviewedAt DateTime?

  verifiedAt DateTime?

  ///////////////////////////////////////////////////////////
  // FUTURE OWNERSHIP
  ///////////////////////////////////////////////////////////

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  ///////////////////////////////////////////////////////////
  // COMMERCIAL (pay-per-lead)
  ///////////////////////////////////////////////////////////

  /**
   * Populated at request creation by deriveLeadValue (packages/domain
   * lead-value) from the normalized request signals; admin can override via
   * request-commercial-settings. `unlock-request` charges `creditCost` and
   * enforces `maxUnlocks`.
   */

  creditCost  Int?
  maxUnlocks  Int?
  unlockCount Int  @default(0)

  /**
   * Automatic lead-value snapshot produced by deriveLeadValue at creation.
   * MONETIZATION world, kept SEPARATE from `structuredData` (funnel/draft
   * world). Shape: { policyVersion, creditCost, maxUnlocks, tier, score,
   * belowFloor, reasons }. Preserved across admin overrides; never selected in
   * listings.
   */
  commercialSnapshot Json?

  /**
   * Admin commercial override — the admin CORRECTS, never REPLACES: the auto
   * snapshot above stays intact. Same flat attribution pattern as the
   * archive / soft-delete admin actions below (…At / …ByAdminUserId / …Reason,
   * FK to User, onDelete: SetNull). `commercialOverriddenAt IS NOT NULL` marks
   * a manually corrected effective creditCost/maxUnlocks.
   */
  commercialOverriddenAt            DateTime?
  commercialOverriddenByAdminUserId String?
  commercialOverriddenByAdminUser   User?     @relation("RequestCommercialOverriddenBy", fields: [commercialOverriddenByAdminUserId], references: [id], onDelete: SetNull)
  commercialOverrideReason          String?

  ///////////////////////////////////////////////////////////
  // ADMIN LIFECYCLE (archive / soft-delete) — D-020
  ///////////////////////////////////////////////////////////

  /**
   * Archiving hides a request from default admin/marketplace lists while
   * keeping all data and history. Independent of `status`: an archived
   * request keeps whatever editorial status it already had. Reversible.
   */
  archivedAt            DateTime?
  archivedByAdminUserId String?
  archivedByAdminUser   User?     @relation("RequestArchivedBy", fields: [archivedByAdminUserId], references: [id], onDelete: SetNull)
  archiveReason         String?

  /**
   * Soft-delete only: never a hard delete. Excludes the request from every
   * default admin/marketplace list. Existing company relationships
   * (unlocks, conversations, credit transactions) are never touched.
   * Reversible.
   */
  deletedAt            DateTime?
  deletedByAdminUserId String?
  deletedByAdminUser   User?     @relation("RequestDeletedBy", fields: [deletedByAdminUserId], references: [id], onDelete: SetNull)
  deleteReason         String?

  ///////////////////////////////////////////////////////////
  // TIMESTAMPS
  ///////////////////////////////////////////////////////////

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ///////////////////////////////////////////////////////////
  // RELATIONS
  ///////////////////////////////////////////////////////////

  photos               RequestPhoto[]
  accessTokens         CustomerAccessToken[]
  unlocks              RequestUnlock[]
  savedByCompanies     CompanySavedRequest[]
  dispatches           RequestDispatch[]
  companyNotifications CompanyNotification[]
  creditTransactions   CompanyCreditTransaction[]
  creditRefundRequests CreditRefundRequest[]

  ///////////////////////////////////////////////////////////
  // INDEXES
  ///////////////////////////////////////////////////////////
  conversations Conversation[]

  @@index([status])
  @@index([createdAt])
  @@index([customerEmail])
  @@index([customerId])
  @@index([interventionSlug])
  @@index([interventionId])
  @@index([status, createdAt])
  @@index([customerId, createdAt])
  @@index([status, creditCost])
  @@index([unlockCount])
  @@index([archivedAt])
  @@index([deletedAt])
  @@index([archivedByAdminUserId])
  @@index([deletedByAdminUserId])
  @@index([commercialOverriddenByAdminUserId])
}

model RequestPhoto {
  id String @id @default(cuid())

  uploadId  String @unique
  fileKey   String @unique
  fileName  String
  mimeType  String
  sizeBytes Int

  status RequestPhotoStatus @default(TEMPORARY)

  requestId String?
  request   Request? @relation(fields: [requestId], references: [id], onDelete: Cascade)

  attachedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([requestId])
}

///////////////////////////////////////////////////////////
// REQUEST DISPATCH / NOTIFICATION LAYER
///////////////////////////////////////////////////////////

model RequestDispatch {
  id String @id @default(cuid())

  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  status RequestDispatchStatus @default(CREATED)

  distanceKm  Float?
  matchReason Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyNotifications   CompanyNotification[]
  notificationDeliveries NotificationDelivery[]

  @@unique([requestId, companyId])
  @@index([requestId, createdAt])
  @@index([companyId, createdAt])
  @@index([status, createdAt])
}

model CompanyNotification {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  requestId String?
  request   Request? @relation(fields: [requestId], references: [id], onDelete: Cascade)

  requestDispatchId String?
  requestDispatch   RequestDispatch? @relation(fields: [requestDispatchId], references: [id], onDelete: Cascade)

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  messageId String?
  message   Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  type CompanyNotificationType

  title String
  body  String

  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([companyId, readAt, createdAt])
  @@index([requestId])
  @@index([requestDispatchId])
  @@index([conversationId])
  @@index([messageId])
}

model NotificationDelivery {
  id String @id @default(cuid())

  requestDispatchId String
  requestDispatch   RequestDispatch @relation(fields: [requestDispatchId], references: [id], onDelete: Cascade)

  channel NotificationChannel
  status  NotificationDeliveryStatus @default(PENDING)

  recipient String?

  provider          String?
  providerMessageId String?

  idempotencyKey String @unique

  attemptCount Int     @default(0)
  lastError    String?

  nextAttemptAt DateTime?
  sentAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requestDispatchId])
  @@index([status, nextAttemptAt])
  @@index([channel, status])
}

///////////////////////////////////////////////////////////
// IDENTITY / AUTHORIZATION LAYER
///////////////////////////////////////////////////////////

enum CompanyMemberRole {
  OWNER
  MANAGER
  STAFF
}

model CreditPackage {
  id String @id @default(cuid())

  name        String
  description String?

  credits    Int
  priceCents Int
  currency   String @default("EUR")

  validityDays Int @default(30)

  status    CreditPackageStatus @default(ACTIVE)
  sortOrder Int                 @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders CreditOrder[]

  @@index([status, sortOrder])
  @@index([status, validityDays])
  @@index([createdAt])
}

model CompanyCreditAccount {
  id String @id @default(cuid())

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  balance Int @default(0)

  /**
   * Credit validity is enforced lazily by future mutative credit operations.
   * No cron or scheduled expiration worker is part of this release path.
   */
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions CompanyCreditTransaction[]

  @@index([expiresAt])
}

model CreditOrder {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  packageId String?
  package   CreditPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  status CreditOrderStatus @default(PENDING)

  credits     Int
  amountCents Int
  currency    String @default("EUR")

  provider                String?
  providerCheckoutId      String?   @unique
  providerPaymentIntentId String?   @unique
  providerEventId         String?
  paidAt                  DateTime?
  validFrom               DateTime?
  validUntil              DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions CompanyCreditTransaction[]
  creditLots   CreditLot[]

  @@index([companyId, status])
  @@index([packageId])
  @@index([createdAt])
  @@index([validUntil])
}

model CompanyCreditTransaction {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  accountId String
  account   CompanyCreditAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  type   CreditTransactionType
  status CreditTransactionStatus @default(COMPLETED)

  /**
   * Positive amounts add credits.
   * Negative amounts subtract credits.
   */
  amount        Int
  balanceBefore Int @default(0)
  balanceAfter  Int

  expiresAtBefore DateTime?
  expiresAtAfter  DateTime?

  requestId String?
  request   Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  creditOrderId String?
  creditOrder   CreditOrder? @relation(fields: [creditOrderId], references: [id], onDelete: SetNull)

  /**
   * Refund transactions must point to the original transaction.
   * The unique relatedTransactionId prevents refunding the same source transaction twice.
   * Example:
   * REFUND.relatedTransactionId -> REQUEST_UNLOCK transaction id.
   */
  relatedTransactionId String?                   @unique
  relatedTransaction   CompanyCreditTransaction? @relation("CreditTransactionReversal", fields: [relatedTransactionId], references: [id], onDelete: SetNull)
  reversalTransaction  CompanyCreditTransaction? @relation("CreditTransactionReversal")

  adminUserId String?
  adminUser   User?   @relation("CreditAdminActor", fields: [adminUserId], references: [id], onDelete: SetNull)

  reason         String?
  metadata       Json?
  idempotencyKey String? @unique

  createdAt DateTime @default(now())

  unlockChargeFor      RequestUnlock?        @relation("RequestUnlockCharge")
  unlockRefundFor      RequestUnlock?        @relation("RequestUnlockRefund")
  creditRefundRequests CreditRefundRequest[]
  lotConsumptions      CreditLotConsumption[]

  @@index([companyId, createdAt])
  @@index([accountId, createdAt])
  @@index([requestId])
  @@index([creditOrderId])
  @@index([type, status])
  @@index([adminUserId])
}

///////////////////////////////////////////////////////////
// CREDIT LOTS (FEFO) — D-011
///////////////////////////////////////////////////////////

enum CreditLotSource {
  PACKAGE_PURCHASE
  REFUND
  ADMIN_ADJUSTMENT
  LEGACY_MIGRATION
}

enum CreditLotStatus {
  ACTIVE
  EXPIRED
  CONSUMED
}

model CreditLot {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /**
   * Null for lots not tied to a single purchase (refund, admin adjustment,
   * legacy migration of the pre-FEFO pooled balance).
   */
  creditOrderId String?
  creditOrder   CreditOrder? @relation(fields: [creditOrderId], references: [id], onDelete: SetNull)

  source CreditLotSource

  /**
   * quantityRemaining is decremented by FEFO consumption and by lazy
   * per-lot expiration. quantityInitial never changes after creation.
   * Invariant: quantityRemaining = quantityInitial - SUM(consumptions.amount).
   */
  quantityInitial   Int
  quantityRemaining Int

  /**
   * Each lot owns its own expiry. A new purchase/refund never extends the
   * expiresAt of a previously existing lot (D-011 requirement).
   */
  expiresAt DateTime

  status CreditLotStatus @default(ACTIVE)

  /**
   * Idempotency for lot creation (one lot per fulfillment/refund/admin
   * event/migration backfill).
   */
  idempotencyKey String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consumptions CreditLotConsumption[]

  @@index([companyId, status, expiresAt])
  @@index([creditOrderId])
}

model CreditLotConsumption {
  id String @id @default(cuid())

  creditLotId String
  creditLot   CreditLot @relation(fields: [creditLotId], references: [id], onDelete: Cascade)

  creditTransactionId String
  creditTransaction   CompanyCreditTransaction @relation(fields: [creditTransactionId], references: [id], onDelete: Cascade)

  /**
   * Amount removed from creditLot.quantityRemaining by this transaction.
   * Always positive: covers both FEFO debit consumption and per-lot expiration write-off.
   */
  amount Int

  createdAt DateTime @default(now())

  @@unique([creditLotId, creditTransactionId])
  @@index([creditLotId])
  @@index([creditTransactionId])
}

model RequestUnlock {
  id String @id @default(cuid())

  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  creditCost Int

  creditTransactionId String                   @unique
  creditTransaction   CompanyCreditTransaction @relation("RequestUnlockCharge", fields: [creditTransactionId], references: [id], onDelete: Restrict)

  refundedAt DateTime?

  refundTransactionId String?                   @unique
  refundTransaction   CompanyCreditTransaction? @relation("RequestUnlockRefund", fields: [refundTransactionId], references: [id], onDelete: SetNull)

  refundReason  String?
  refundRequest CreditRefundRequest?

  createdAt     DateTime       @default(now())
  conversations Conversation[]

  @@unique([requestId, companyId])
  @@index([requestId, createdAt])
  @@index([companyId, createdAt])
  @@index([refundedAt])
  @@index([companyId, requestId], map: "idx_request_unlock_company_request_s6b")
}

model CompanySavedRequest {
  companyId String
  requestId String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@id([companyId, requestId])
  @@index([requestId])
  @@index([companyId, createdAt])
}

model CreditRefundRequest {
  id String @id @default(cuid())

  requestUnlockId String        @unique
  requestUnlock   RequestUnlock @relation(fields: [requestUnlockId], references: [id], onDelete: Cascade)

  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  creditTransactionId String
  creditTransaction   CompanyCreditTransaction @relation(fields: [creditTransactionId], references: [id], onDelete: Restrict)

  status      CreditRefundRequestStatus @default(PENDING_REVIEW)
  reason      CreditRefundRequestReason
  description String

  companyContactAttempted Boolean   @default(false)
  lastContactAttemptAt    DateTime?

  reviewedAt            DateTime?
  reviewedByAdminUserId String?
  reviewedByAdminUser   User?     @relation("CreditRefundReviewAdmin", fields: [reviewedByAdminUserId], references: [id], onDelete: SetNull)
  adminNotes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([companyId, createdAt])
  @@index([requestId])
  @@index([reviewedByAdminUserId])
}

enum CreditRefundRequestStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  CANCELLED
}

enum CreditRefundRequestReason {
  CUSTOMER_NOT_RESPONDING
  INVALID_CONTACTS
  REQUEST_ALREADY_RESOLVED
  INVALID_OR_SPAM_REQUEST
  DUPLICATE_REQUEST
  OTHER
}

enum CreditPackageStatus {
  ACTIVE
  INACTIVE
}

enum CreditOrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum CreditTransactionType {
  PACKAGE_PURCHASE
  REQUEST_UNLOCK
  ADMIN_ADJUSTMENT
  REFUND
  CREDIT_EXPIRATION
}

enum CreditTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum CustomerTokenPurpose {
  CONVERSATION_ACCESS
  REQUEST_VERIFICATION
  REQUEST_STATUS

  /// Reserved for the future customer review flow.
  REVIEW_ACCESS
}

enum CompanyContactChangeField {
  PHONE
}

enum CompanyContactChangeStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  CANCELLED
}

model CompanyContactChangeRequest {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  requestedByUserId String
  requestedByUser   User   @relation("CompanyContactChangeRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Cascade)

  field CompanyContactChangeField

  currentValue   String?
  requestedValue String

  status CompanyContactChangeStatus @default(PENDING_REVIEW)

  reviewedAt            DateTime?
  reviewedByAdminUserId String?
  reviewedByAdminUser   User?     @relation("CompanyContactChangeReviewedBy", fields: [reviewedByAdminUserId], references: [id], onDelete: SetNull)

  adminNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, createdAt])
  @@index([status, createdAt])
  @@index([reviewedByAdminUserId])
}

///////////////////////////////////////////////////////////
// CONVERSATION / MESSAGING LAYER
///////////////////////////////////////////////////////////

enum ConversationType {
  COMPANY_CUSTOMER
  SUPPORT
  COMPANY_ADMIN
  ADMIN_CUSTOMER
  INTERNAL_ADMIN
}

enum ConversationActorType {
  USER
  CUSTOMER
  COMPANY
  ADMIN
}

model Conversation {
  id String @id @default(cuid())

  type ConversationType

  requestId String?
  request   Request? @relation(fields: [requestId], references: [id], onDelete: Cascade)

  requestUnlockId String?
  requestUnlock   RequestUnlock? @relation(fields: [requestUnlockId], references: [id], onDelete: Cascade)

  isResolved   Boolean   @default(false)
  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?     @relation("ConversationResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
  companyNotifications CompanyNotification[]

  @@index([type, createdAt])
  @@index([type, isResolved, updatedAt])
  @@index([requestId])
  @@index([requestUnlockId])
  @@index([resolvedById])
  @@index([requestId], map: "idx_conversation_request_s6b")
}

model ConversationParticipant {
  id String @id @default(cuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  actorType ConversationActorType

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  lastReadAt DateTime?

  createdAt DateTime @default(now())

  sentMessages Message[]

  @@index([conversationId])
  @@index([userId])
  @@index([customerId])
  @@index([companyId])
  @@index([conversationId, actorType], map: "idx_conversation_participant_conversation_actor_s6b")
  @@index([companyId, actorType, conversationId], map: "idx_conversation_participant_company_actor_conversation_s6b")
  @@index([customerId, actorType, conversationId], map: "idx_conversation_participant_customer_actor_conversation_s6b")
}

model Message {
  id String @id @default(cuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderParticipantId String
  senderParticipant   ConversationParticipant @relation(fields: [senderParticipantId], references: [id], onDelete: Cascade)

  body String

  deletedAt DateTime?

  createdAt DateTime @default(now())

  companyNotifications CompanyNotification[]

  @@index([conversationId, createdAt])
  @@index([senderParticipantId])
}
