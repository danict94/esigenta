generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

///////////////////////////////////////////////////////////
// CORE ORGANIZATION LAYER
///////////////////////////////////////////////////////////

model Sector {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories Category[]

  @@index([slug])
}

model Category {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?

  /**
   * PROFESSIONAL IDENTITY
   * Category defines:
   * - professional identity
   * - onboarding grouping
   * - navigation grouping
   * - trust grouping
   * Category is NOT:
   * - operational matching
   * - notification routing
   * - SEO runtime
   */

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sectorId String
  sector   Sector @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  services CategoryService[]
  aliases  CategoryAlias[]

  @@index([slug])
  @@index([sectorId])
}

///////////////////////////////////////////////////////////
// REAL OPERATIONAL CAPABILITIES
///////////////////////////////////////////////////////////

model Service {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?

  /**
   * REAL OPERATIONAL CAPABILITY
   * Service defines:
   * - operational capabilities
   * - matching capabilities
   * - notification capabilities
   * Service is NOT:
   * - SEO
   * - navigation
   * - customer intent
   */

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories    CategoryService[]
  interventions InterventionService[]
  aliases       ServiceAlias[]

  companyServices         CompanyService[]
  requestRequiredServices RequestRequiredService[]

  @@index([slug])
  @@index([name])
}

///////////////////////////////////////////////////////////
// CUSTOMER INTENT LAYER
///////////////////////////////////////////////////////////

model Intervention {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?

  /**
   * CUSTOMER INTENT
   * Represents:
   * - customer goals
   * - customer language
   * - customer problems
   * - funnel entry
   * Intervention is NOT:
   * - operational capability
   */

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services InterventionService[]
  domains  DomainIntervention[]

  aliases InterventionAlias[]

  @@index([slug])
  @@index([name])
}

///////////////////////////////////////////////////////////
// SEO / NAVIGATION LAYER
///////////////////////////////////////////////////////////

model Domain {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?

  /**
   * SEO + NAVIGATION ONLY
   * Domain defines:
   * - SEO hubs
   * - navigation clusters
   * - discovery grouping
   * Domain MUST NEVER:
   * - drive runtime matching
   * - drive notification routing
   * - drive operational filtering
   */

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  interventions DomainIntervention[]

  aliases DomainAlias[]

  @@index([slug])
  @@index([name])
}

///////////////////////////////////////////////////////////
// ALIASES
///////////////////////////////////////////////////////////

model InterventionAlias {
  id String @id @default(cuid())

  value String @unique

  interventionId String
  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([value])
  @@index([interventionId])
}

model ServiceAlias {
  id String @id @default(cuid())

  value String @unique

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([value])
  @@index([serviceId])
}

model CategoryAlias {
  id String @id @default(cuid())

  value String @unique

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([value])
  @@index([categoryId])
}

model DomainAlias {
  id String @id @default(cuid())

  value String @unique

  domainId String
  domain   Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([value])
  @@index([domainId])
}

///////////////////////////////////////////////////////////
// GRAPH RELATIONS
///////////////////////////////////////////////////////////

model CategoryService {
  categoryId String
  serviceId  String

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([categoryId, serviceId])
  @@index([categoryId])
  @@index([serviceId])
}

model InterventionService {
  interventionId String
  serviceId      String

  intervention Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([interventionId, serviceId])
  @@index([interventionId])
  @@index([serviceId])
}

model DomainIntervention {
  domainId       String
  interventionId String

  domain       Domain       @relation(fields: [domainId], references: [id], onDelete: Cascade)
  intervention Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)

  @@id([domainId, interventionId])
  @@index([domainId])
  @@index([interventionId])
}

///////////////////////////////////////////////////////////
// RUNTIME OPERATIONAL LAYER
///////////////////////////////////////////////////////////

model Company {
  id String @id @default(cuid())

  name              String
  vatNumber         String  @unique
  phone             String
  website           String?
  address           String?
  street            String?
  streetNo          String?
  city              String?
  postalCode        String?
  province          String?
  latitude          Float?
  longitude         Float?
  operatingRadiusKm Int     @default(30)

  /**
   * IMPORTANT
   * Company capabilities are defined ONLY by:
   * CompanyService
   * NOT:
   * - categories
   * - sectors
   * - SEO
   */

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services    CompanyService[]
  memberships CompanyMembership[]

  @@index([vatNumber])
  @@index([city])
  @@index([postalCode])
  @@index([latitude, longitude])
  @@index([createdAt])
}

model CompanyService {
  companyId String
  serviceId String

  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([companyId, serviceId])
  @@index([companyId])
  @@index([serviceId])
}

///////////////////////////////////////////////////////////
// REQUEST SNAPSHOT LAYER
///////////////////////////////////////////////////////////

enum RequestStatus {
  DRAFT
  PENDING_VERIFICATION
  PENDING_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
  CLOSED
}

model User {
  id String @id @default(cuid())

  /**
   * HARD AUTH IDENTITY
   * User represents authenticated actors:
   * - company operators
   * - admin operators
   * User is NOT required for lightweight customer funnel flow.
   */

  email String  @unique
  name  String?

  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  image           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyMemberships CompanyMembership[]
  adminProfile       AdminProfile?

  sessions Session[]
  accounts Account[]
}

model Session {
  id String @id @default(cuid())

  expiresAt DateTime
  token     String   @unique

  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id String @id @default(cuid())

  accountId  String
  providerId String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([providerId, accountId])
}

model Verification {
  id String @id @default(cuid())

  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
}

model Customer {
  id String @id @default(cuid())

  /**
   * SOFT CUSTOMER IDENTITY
   * Customer is created/linked from funnel request verification.
   * It must remain lightweight:
   * - no mandatory password
   * - no forced registration
   * - used for request status/reviews/history
   */

  email String  @unique
  name  String?
  phone String?

  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requests Request[]
}

model CompanyMembership {
  id String @id @default(cuid())

  /**
   * COMPANY ACCESS CONTROL
   * Defines which authenticated User can operate a Company.
   * Company operational profile remains on Company.
   * Services remain on CompanyService.
   * Coverage/radius must remain company-level, not user-level.
   */

  companyId String
  userId    String

  role CompanyMemberRole @default(STAFF)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
  @@index([companyId, role])
}

model AdminProfile {
  id String @id @default(cuid())

  /**
   * ADMIN ACCESS CONTROL
   * Admin access is separate from company access.
   * A User becomes an admin only if an AdminProfile exists.
   */

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role AdminRole @default(ADMIN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model CustomerAccessToken {
  id String @id @default(cuid())

  /**
   * CUSTOMER TOKEN ACCESS
   * Used for:
   * - request email verification
   * - request status access
   * - review access
   * Store only tokenHash, never raw token.
   */

  tokenHash String @unique

  purpose CustomerTokenPurpose

  email String

  requestId String?
  request   Request? @relation(fields: [requestId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([email, purpose])
  @@index([requestId])
  @@index([purpose, expiresAt])
  @@index([expiresAt])
}

model Request {
  id          String  @id @default(cuid())
  requestCode String? @unique

  /**
   * MARKETPLACE REQUEST LIFECYCLE
   * Request represents:
   * - verified customer intent
   * - operational request snapshot
   * - marketplace moderation unit
   * Request MUST remain:
   * - taxonomy-independent
   * - runtime-stable
   * - historically stable
   */

  status RequestStatus @default(DRAFT)

  ///////////////////////////////////////////////////////////
  // TAXONOMY SNAPSHOT
  ///////////////////////////////////////////////////////////

  interventionSlug String?

  ///////////////////////////////////////////////////////////
  // CUSTOMER SNAPSHOT
  ///////////////////////////////////////////////////////////

  customerName  String?
  customerEmail String?
  customerPhone String?

  ///////////////////////////////////////////////////////////
  // GEO SNAPSHOT
  ///////////////////////////////////////////////////////////

  city       String?
  address    String?
  postalCode String?

  latitude  Float?
  longitude Float?

  ///////////////////////////////////////////////////////////
  // FUNNEL SNAPSHOT
  ///////////////////////////////////////////////////////////

  /**
   * IMPORTANT
   * Stores:
   * - runtime answers
   * - funnel structured data
   * - operational context
   * Avoid rigid funnel columns.
   */

  structuredData Json?

  ///////////////////////////////////////////////////////////
  // MODERATION
  ///////////////////////////////////////////////////////////

  moderationNotes String?

  reviewedAt DateTime?

  verifiedAt DateTime?

  ///////////////////////////////////////////////////////////
  // FUTURE OWNERSHIP
  ///////////////////////////////////////////////////////////

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  ///////////////////////////////////////////////////////////
  // FUTURE COMMERCIAL
  ///////////////////////////////////////////////////////////

  /**
   * NOT active yet.
   * Only preparation.
   */

  creditCost Int?

  ///////////////////////////////////////////////////////////
  // TIMESTAMPS
  ///////////////////////////////////////////////////////////

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ///////////////////////////////////////////////////////////
  // RELATIONS
  ///////////////////////////////////////////////////////////

  requiredServices RequestRequiredService[]
  accessTokens     CustomerAccessToken[]

  ///////////////////////////////////////////////////////////
  // INDEXES
  ///////////////////////////////////////////////////////////

  @@index([status])
  @@index([createdAt])
  @@index([customerEmail])
  @@index([customerId])
  @@index([interventionSlug])
  @@index([city])
}

model RequestRequiredService {
  requestId String
  serviceId String

  createdAt DateTime @default(now())

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  /**
   * SNAPSHOT RELATION
   * Restrict deletion because:
   * historical requests must remain stable.
   */
  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@id([requestId, serviceId])
  @@index([requestId])
  @@index([serviceId])
}

///////////////////////////////////////////////////////////
// IDENTITY / AUTHORIZATION LAYER
///////////////////////////////////////////////////////////

enum CompanyMemberRole {
  OWNER
  MANAGER
  STAFF
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum CustomerTokenPurpose {
  REQUEST_VERIFICATION
  REQUEST_STATUS
  REVIEW_ACCESS
}
