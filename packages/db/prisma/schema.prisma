generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

///////////////////////////////////////////////////////////
// CORE ORGANIZATION LAYER
///////////////////////////////////////////////////////////

model Sector {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories Category[]
}

model Category {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?

  /**
   * PROFESSIONAL IDENTITY
   * Category defines:
   * - professional identity
   * - onboarding grouping
   * - navigation grouping
   * - trust grouping
   * Category is NOT:
   * - operational matching
   * - notification routing
   * - SEO runtime
   */

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sectorId String
  sector   Sector @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  services CategoryService[]
  aliases  CategoryAlias[]

  @@index([sectorId])
}

///////////////////////////////////////////////////////////
// REAL OPERATIONAL CAPABILITIES
///////////////////////////////////////////////////////////

model Service {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?

  /**
   * REAL OPERATIONAL CAPABILITY
   * Service defines:
   * - operational capabilities
   * - matching capabilities
   * - notification capabilities
   * Service is NOT:
   * - SEO
   * - navigation
   * - customer intent
   */

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories    CategoryService[]
  interventions InterventionService[]
  aliases       ServiceAlias[]

  companyServices         CompanyService[]
  requestRequiredServices RequestRequiredService[]

  @@index([name])
}

///////////////////////////////////////////////////////////
// CUSTOMER INTENT LAYER
///////////////////////////////////////////////////////////

model Intervention {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?

  /**
   * CUSTOMER INTENT
   * Represents:
   * - customer goals
   * - customer language
   * - customer problems
   * - funnel entry
   * Intervention is NOT:
   * - operational capability
   */

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services InterventionService[]
  domains  DomainIntervention[]

  aliases InterventionAlias[]

  @@index([name])
}

///////////////////////////////////////////////////////////
// SEO / NAVIGATION LAYER
///////////////////////////////////////////////////////////

model Domain {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?

  /**
   * SEO + NAVIGATION ONLY
   * Domain defines:
   * - SEO hubs
   * - navigation clusters
   * - discovery grouping
   * Domain MUST NEVER:
   * - drive runtime matching
   * - drive notification routing
   * - drive operational filtering
   */

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  interventions DomainIntervention[]

  aliases DomainAlias[]

  @@index([name])
}

///////////////////////////////////////////////////////////
// ALIASES
///////////////////////////////////////////////////////////

model InterventionAlias {
  id String @id @default(cuid())

  value String @unique

  interventionId String
  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([interventionId])
}

model ServiceAlias {
  id String @id @default(cuid())

  value String @unique

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([serviceId])
}

model CategoryAlias {
  id String @id @default(cuid())

  value String @unique

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([categoryId])
}

model DomainAlias {
  id String @id @default(cuid())

  value String @unique

  domainId String
  domain   Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([domainId])
}

///////////////////////////////////////////////////////////
// GRAPH RELATIONS
///////////////////////////////////////////////////////////

model CategoryService {
  categoryId String
  serviceId  String

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([categoryId, serviceId])
  @@index([categoryId])
  @@index([serviceId])
}

model InterventionService {
  interventionId String
  serviceId      String

  intervention Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([interventionId, serviceId])
  @@index([interventionId])
  @@index([serviceId])
}

model DomainIntervention {
  domainId       String
  interventionId String

  domain       Domain       @relation(fields: [domainId], references: [id], onDelete: Cascade)
  intervention Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)

  @@id([domainId, interventionId])
  @@index([domainId])
  @@index([interventionId])
}

///////////////////////////////////////////////////////////
// RUNTIME OPERATIONAL LAYER
///////////////////////////////////////////////////////////

model Company {
  id String @id @default(cuid())

  name              String
  vatNumber         String  @unique
  phone             String
  website           String?
  address           String?
  street            String?
  streetNo          String?
  city              String?
  postalCode        String?
  province          String?
  latitude          Float?
  longitude         Float?
  operatingRadiusKm Int     @default(30)

  /**
   * ONBOARDING CONTEXT ONLY
   * Captures the professional category selected in the public signup flow.
   * Matching must remain based on CompanyService, never this field.
   */
  onboardingCategorySlug String?

  /**
   * IMPORTANT
   * Company capabilities are defined ONLY by:
   * CompanyService
   * NOT:
   * - categories
   * - sectors
   * - SEO
   */

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services    CompanyService[]
  memberships CompanyMembership[]

  creditAccount      CompanyCreditAccount?
  creditOrders       CreditOrder[]
  creditTransactions CompanyCreditTransaction[]
  requestUnlocks     RequestUnlock[]

  @@index([city])
  @@index([postalCode])
  @@index([latitude, longitude])
  @@index([onboardingCategorySlug])
  @@index([createdAt])
}

model CompanyService {
  companyId String
  serviceId String

  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([companyId, serviceId])
  @@index([companyId])
  @@index([serviceId])
}

///////////////////////////////////////////////////////////
// REQUEST SNAPSHOT LAYER
///////////////////////////////////////////////////////////

enum RequestStatus {
  DRAFT
  PENDING_VERIFICATION
  PENDING_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
  CLOSED
}

model User {
  id String @id @default(cuid())

  /**
   * HARD AUTH IDENTITY
   * User represents authenticated actors:
   * - company operators
   * - admin operators
   * User is NOT required for lightweight customer funnel flow.
   */

  email String  @unique
  name  String?

  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  image           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyMemberships      CompanyMembership[]
  adminProfile            AdminProfile?
  adminCreditTransactions CompanyCreditTransaction[] @relation("CreditAdminActor")

  sessions Session[]
  accounts Account[]
}

model Session {
  id String @id @default(cuid())

  expiresAt DateTime
  token     String   @unique

  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id String @id @default(cuid())

  accountId  String
  providerId String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([providerId, accountId])
}

model Verification {
  id String @id @default(cuid())

  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
}

model Customer {
  id String @id @default(cuid())

  /**
   * SOFT CUSTOMER IDENTITY
   * Customer is created/linked from funnel request verification.
   * It must remain lightweight:
   * - no mandatory password
   * - no forced registration
   * - used for request status/reviews/history
   */

  email String  @unique
  name  String?
  phone String?

  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requests Request[]
}

model CompanyMembership {
  id String @id @default(cuid())

  /**
   * COMPANY ACCESS CONTROL
   * Defines which authenticated User can operate a Company.
   * Company operational profile remains on Company.
   * Services remain on CompanyService.
   * Coverage/radius must remain company-level, not user-level.
   */

  companyId String
  userId    String

  role CompanyMemberRole @default(STAFF)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
  @@index([companyId, role])
}

model AdminProfile {
  id String @id @default(cuid())

  /**
   * ADMIN ACCESS CONTROL
   * Admin access is separate from company access.
   * A User becomes an admin only if an AdminProfile exists.
   */

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role AdminRole @default(ADMIN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model CustomerAccessToken {
  id String @id @default(cuid())

  /**
   * CUSTOMER TOKEN ACCESS
   * Used for:
   * - request email verification
   * - request status access
   * - review access
   * Store only tokenHash, never raw token.
   */

  tokenHash String @unique

  purpose CustomerTokenPurpose

  email String

  requestId String?
  request   Request? @relation(fields: [requestId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([email, purpose])
  @@index([requestId])
  @@index([purpose, expiresAt])
  @@index([expiresAt])
}

model Request {
  id          String  @id @default(cuid())
  requestCode String? @unique

  /**
   * MARKETPLACE REQUEST LIFECYCLE
   * Request represents:
   * - verified customer intent
   * - operational request snapshot
   * - marketplace moderation unit
   * Request MUST remain:
   * - taxonomy-independent
   * - runtime-stable
   * - historically stable
   */

  status RequestStatus @default(DRAFT)

  ///////////////////////////////////////////////////////////
  // TAXONOMY SNAPSHOT
  ///////////////////////////////////////////////////////////

  interventionSlug String?

  ///////////////////////////////////////////////////////////
  // CUSTOMER SNAPSHOT
  ///////////////////////////////////////////////////////////

  customerName  String?
  customerEmail String?
  customerPhone String?

  ///////////////////////////////////////////////////////////
  // GEO SNAPSHOT
  ///////////////////////////////////////////////////////////

  city       String?
  address    String?
  postalCode String?

  latitude  Float?
  longitude Float?

  ///////////////////////////////////////////////////////////
  // FUNNEL SNAPSHOT
  ///////////////////////////////////////////////////////////

  /**
   * IMPORTANT
   * Stores:
   * - runtime answers
   * - funnel structured data
   * - operational context
   * Avoid rigid funnel columns.
   */

  structuredData Json?

  ///////////////////////////////////////////////////////////
  // MODERATION
  ///////////////////////////////////////////////////////////

  moderationNotes String?

  reviewedAt DateTime?

  verifiedAt DateTime?

  ///////////////////////////////////////////////////////////
  // FUTURE OWNERSHIP
  ///////////////////////////////////////////////////////////

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  ///////////////////////////////////////////////////////////
  // FUTURE COMMERCIAL
  ///////////////////////////////////////////////////////////

  /**
   * NOT active yet.
   * Only preparation.
   */

  creditCost  Int?
  maxUnlocks  Int?
  unlockCount Int  @default(0)

  ///////////////////////////////////////////////////////////
  // TIMESTAMPS
  ///////////////////////////////////////////////////////////

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ///////////////////////////////////////////////////////////
  // RELATIONS
  ///////////////////////////////////////////////////////////

  requiredServices   RequestRequiredService[]
  accessTokens       CustomerAccessToken[]
  unlocks            RequestUnlock[]
  creditTransactions CompanyCreditTransaction[]

  ///////////////////////////////////////////////////////////
  // INDEXES
  ///////////////////////////////////////////////////////////

  @@index([status])
  @@index([createdAt])
  @@index([customerEmail])
  @@index([customerId])
  @@index([interventionSlug])
  @@index([city])
  @@index([status, createdAt])
  @@index([customerId, createdAt])
  @@index([latitude, longitude])
  @@index([status, creditCost])
  @@index([unlockCount])
}

model RequestRequiredService {
  requestId String
  serviceId String

  createdAt DateTime @default(now())

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  /**
   * SNAPSHOT RELATION
   * Restrict deletion because:
   * historical requests must remain stable.
   */
  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@id([requestId, serviceId])
  @@index([requestId])
  @@index([serviceId])
}

///////////////////////////////////////////////////////////
// IDENTITY / AUTHORIZATION LAYER
///////////////////////////////////////////////////////////

enum CompanyMemberRole {
  OWNER
  MANAGER
  STAFF
}

model CreditPackage {
  id String @id @default(cuid())

  name        String
  description String?

  credits    Int
  priceCents Int
  currency   String @default("EUR")

  status    CreditPackageStatus @default(ACTIVE)
  sortOrder Int                 @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders CreditOrder[]

  @@index([status, sortOrder])
  @@index([createdAt])
}

model CompanyCreditAccount {
  id String @id @default(cuid())

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  balance Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions CompanyCreditTransaction[]
}

model CreditOrder {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  packageId String?
  package   CreditPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  status CreditOrderStatus @default(PENDING)

  credits     Int
  amountCents Int
  currency    String @default("EUR")

  provider                String?
  providerCheckoutId      String?   @unique
  providerPaymentIntentId String?   @unique
  providerEventId         String?
  paidAt                  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions CompanyCreditTransaction[]

  @@index([companyId, status])
  @@index([packageId])
  @@index([createdAt])
}

model CompanyCreditTransaction {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  accountId String
  account   CompanyCreditAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  type   CreditTransactionType
  status CreditTransactionStatus @default(COMPLETED)

  /**
   * Positive amounts add credits.
   * Negative amounts subtract credits.
   */
  amount       Int
  balanceAfter Int

  requestId String?
  request   Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  creditOrderId String?
  creditOrder   CreditOrder? @relation(fields: [creditOrderId], references: [id], onDelete: SetNull)

  /**
   * Refund transactions must point to the original transaction.
   * Example:
   * REFUND.relatedTransactionId -> REQUEST_UNLOCK transaction id.
   */
  relatedTransactionId String?                   @unique
  relatedTransaction   CompanyCreditTransaction? @relation("CreditTransactionReversal", fields: [relatedTransactionId], references: [id], onDelete: SetNull)
  reversalTransaction  CompanyCreditTransaction? @relation("CreditTransactionReversal")

  adminUserId String?
  adminUser   User?   @relation("CreditAdminActor", fields: [adminUserId], references: [id], onDelete: SetNull)

  reason         String?
  metadata       Json?
  idempotencyKey String? @unique

  createdAt DateTime @default(now())

  unlockChargeFor RequestUnlock? @relation("RequestUnlockCharge")
  unlockRefundFor RequestUnlock? @relation("RequestUnlockRefund")

  @@index([companyId, createdAt])
  @@index([accountId, createdAt])
  @@index([requestId])
  @@index([creditOrderId])
  @@index([type, status])
  @@index([adminUserId])
}

model RequestUnlock {
  id String @id @default(cuid())

  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  creditCost Int

  creditTransactionId String                   @unique
  creditTransaction   CompanyCreditTransaction @relation("RequestUnlockCharge", fields: [creditTransactionId], references: [id], onDelete: Restrict)

  refundedAt DateTime?

  refundTransactionId String?                   @unique
  refundTransaction   CompanyCreditTransaction? @relation("RequestUnlockRefund", fields: [refundTransactionId], references: [id], onDelete: SetNull)

  refundReason String?

  createdAt DateTime @default(now())

  @@unique([requestId, companyId])
  @@index([requestId, createdAt])
  @@index([companyId, createdAt])
  @@index([refundedAt])
}

enum CreditPackageStatus {
  ACTIVE
  INACTIVE
}

enum CreditOrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum CreditTransactionType {
  PACKAGE_PURCHASE
  REQUEST_UNLOCK
  ADMIN_ADJUSTMENT
  REFUND
}

enum CreditTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum CustomerTokenPurpose {
  REQUEST_VERIFICATION
  REQUEST_STATUS

  /// Reserved for the future customer review flow.
  REVIEW_ACCESS
}
